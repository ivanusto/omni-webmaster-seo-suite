msgid "%1$d-%2$02d"
msgstr "%1$d 年 %2$02d 月"

msgid "(Optional) A common short name for your site, provided to Google as an alternate identifier for the site name."
msgstr "（選填）網站的常用簡稱，提供給 Google 作為站名的替代識別。"

msgid "(Optional) AIzaSy..."
msgstr "（選填）AIzaSy..."

msgid ", "
msgstr "、"

msgid "[Warning] Are you sure you want to delete ALL thumbnails? This removes every image size variant and may cause broken or slow-loading images on the front end. This action cannot be undone!"
msgstr "【警告】您確定要刪除所有的縮圖嗎？這會清除所有圖片版本，可能會導致前端頁面圖片損壞或載入緩慢。此動作無法復原！"

msgid "<strong>Search results (Search)</strong>: sent when a visitor performs an internal site search, including the search keyword the visitor entered."
msgstr "<strong>搜尋結果 (Search)</strong>：當訪客在網站進行內部搜尋時發送，包含訪客輸入的搜尋關鍵字。"

msgid "<strong>Single post/page (ViewContent)</strong>: sent when a visitor views a single post or page, including the post title, all category names, post ID, and post type."
msgstr "<strong>單一文章/頁面 (ViewContent)</strong>：當訪客瀏覽單篇文章或頁面時發送，包含文章標題、全部分類名稱、文章 ID 與文章類型。"

msgid "1536px (1536x1536)"
msgstr "1536 像素 (1536x1536)"

msgid "2048px (2048x2048)"
msgstr "2048 像素 (2048x2048)"

msgid "Advanced RSS Feed Control"
msgstr "進階 RSS Feed 控制"

msgid "All images processed! Scanned %1$s image attachments in total and removed %2$s thumbnail files."
msgstr "全部圖片處理完成！總共掃描 %1$s 張圖片附件，累計清除了 %2$s 個縮圖實體檔案。"

msgid "An error occurred. Please try again."
msgstr "發生錯誤，請重試。"

msgid "Angle / Topics"
msgstr "切角/主題"

msgid "Applies dark styling to the iframe blocks of native WordPress post embeds, ideal for dark-background sites or dark themes."
msgstr "針對 WordPress 原生嵌入文章的 iframe 區塊進行暗色化，適合黑底網站或深色主題。"

msgid "Apply Dark Background and Style Fixes"
msgstr "套用深色背景與樣式修正"

msgid "Are you sure you want to clear all oEmbed preview card caches for the entire site? This forces WordPress to re-fetch embed preview cards on page load (no posts are deleted; only the cache is reset)."
msgstr "您確定要清除全站所有的 oEmbed 預覽卡片快取嗎？這會強制 WordPress 在頁面加載時重新抓取嵌入內容的預覽卡片（此動作不會刪除任何文章，僅重設快取）。"

msgid "Are you sure you want to delete the thumbnail sizes checked as disabled? Only the sizes selected for disabling will be deleted; all other sizes are safely kept. This action cannot be undone!"
msgstr "您確定要刪除已勾選停用的縮圖尺寸嗎？這只會刪除被選定停用的縮圖規格，其餘規格會被安全保留。此動作無法復原！"

msgid "Automatic Slug Translation"
msgstr "中英網址自動翻譯"

msgid "Automatically Track Single Content Views and Search Behavior"
msgstr "自動追蹤單一內容瀏覽與搜尋行為"

msgid "Batch %1$s complete: scanned %2$s images, deleted %3$s thumbnail files."
msgstr "批次 %1$s 處理完成：掃描 %2$s 張，共刪除 %3$s 個縮圖檔案。"

msgid "Batch %1$s: no thumbnails needed deleting."
msgstr "批次 %1$s：無縮圖需要刪除。"

msgid "Batch Clean Existing Thumbnails"
msgstr "批次清理現有縮圖"

msgid "Batch processing in progress. Please do not close this window..."
msgstr "正在批次處理中，請勿關閉視窗..."

msgid "Block every WordPress comment entry point with a single switch, simplifying maintenance for non-community sites while preventing comment spam and improving security."
msgstr "一鍵完全阻斷 WordPress 留言入口，極簡化非社群互動型網站運維，防止垃圾留言侵擾並提升安全。"

msgid "Cache clearing failed due to a database query error."
msgstr "清除失敗，資料庫查詢錯誤。"

msgid "Check a thumbnail size below and newly uploaded images will <strong>no longer</strong> generate physical thumbnails at that size:"
msgstr "勾選下方縮圖規格後，未來上傳的新圖片將<strong>不再</strong>自動生成該尺寸的實體縮圖："

msgid "Choose Cleanup Scope and Mode"
msgstr "選擇清理範圍與模式"

msgid "clean all sizes"
msgstr "清理所有尺寸"

msgid "clean disabled sizes only"
msgstr "僅清理停用尺寸"

msgid "Clean thumbnails of all sizes (not recommended)"
msgstr "清理所有尺寸的縮圖 (不推薦)"

msgid "Clean Up HTML Head"
msgstr "清理 HTML Head"

msgid "Clean WordPress Sitemap"
msgstr "清洗 WordPress Sitemap"

msgid "Cleaning up: %1$s / %2$s images"
msgstr "正在清理中: %1$s / %2$s 張圖片"

msgid "Cleanup complete! All image files have been processed."
msgstr "清理完成！已清理全部圖片檔案。"

msgid "Cleanup process interrupted"
msgstr "清理程序中斷"

msgid "Clear Cache Now"
msgstr "立即清除快取"

msgid "Clearing cache..."
msgstr "正在清理快取中..."

